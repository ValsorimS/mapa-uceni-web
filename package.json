{
  "name": "mapa-uceni-web",
  "version": "1.0.0",
  "private": true,
  "description": "Staticky generovany web Mapa uceni pro rodice deti na ZS.",
  "scripts": {
    "build": "node build.js",
    "check": "npm run validate:rvp && node build.js",
    "check:release": "npm run check && node scripts/release-check.js",
    "check:visual": "npx playwright test scripts/visual-qa.spec.js",
    "validate:rvp": "node scripts/validate-rvp.js",
    "serve": "python3 -m http.server 8080 -d docs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
